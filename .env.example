# --- Dune Configuration ---
DUNE_API_KEY=replace-with-your-dune-api-key
DUNE_QUERY_ID=replace-with-your-dune-query-id

# --- Alchemy Configuration ---
ALCHEMY_WSS_URL=replace-with-your-alchemy-wss-url
