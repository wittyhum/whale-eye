# --- MySQL Configuration ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=whale_eye
DB_POOL_SIZE=5

# --- Business Logic ---
ETH_THRESHOLD=500
SYNC_INTERVAL_HOURS=12
ADDRESS_REFRESH_SECONDS=300
RECONNECT_MAX_SECONDS=60
LOG_LEVEL=INFO

# Optional: map exchange addresses to display names.
# Example:
# KNOWN_EXCHANGES_JSON={"0x28c6c06298d514db089934071355e5743bf21d60":"Binance 14"}
KNOWN_EXCHANGES_JSON={}
