ALCHEMY_SUBSCRIPTION_METHOD=alchemy_subscribe
ALCHEMY_SUBSCRIPTION_TYPE=alchemy_filteredTransfers
NEXT_PUBLIC_API_BASE_URL=http://your-server-ip:8000/api

# --- Telegram Configuration ---
TG_BOT_TOKEN=replace-with-your-telegram-bot-token
TG_CHAT_ID=replace-with-your-chat-id
